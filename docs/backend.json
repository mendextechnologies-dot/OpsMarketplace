
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user information and role",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["sme", "consultant", "admin", "partner"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "OrganisationProfile": {
      "title": "Organisation Profile",
      "description": "Detailed business info for SMEs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "industry": { "type": "string" },
        "employeeCount": { "type": "number" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ConsultantProfile": {
      "title": "Consultant Profile",
      "description": "Professional details for consultants",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "description": { "type": "string" },
        "yearsExperience": { "type": "number" },
        "servicesOffered": { "type": "array", "items": { "type": "string" } },
        "statesCovered": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PartnerProfile": {
      "title": "Partner Profile",
      "description": "Professional details for channel partners",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "partnerName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "servicesFocus": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "An SME's request for professional services",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "isGuestRequest": { "type": "boolean" },
        "leadOwnerType": { "type": "string", "enum": ["sme", "admin", "partner"] },
        "leadOwnerId": { "type": "string" },
        "ownershipStatus": { "type": "string", "enum": ["active", "transferred", "disputed"] },
        "companyUniqueKey": { "type": "string" },
        "duplicateFlag": { "type": "boolean" },
        "consultantCommunicatesWith": { "type": "string", "enum": ["sme", "partner"] },
        "categoryId": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" } },
        "companyName": { "type": "string" },
        "description": { "type": "string" },
        "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["new", "assigned", "completed"] },
        "ai_metadata": {
          "type": "object",
          "properties": {
            "quality_score": { "type": "number" },
            "reasoning": { "type": "string" },
            "intent_clarity": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LeadAssignment": {
      "title": "Lead Assignment",
      "description": "Mapping of a request to a matching consultant",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "consultantId": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "viewed", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account data"
    },
    "/organisationProfiles/{userId}": {
      "schema": "OrganisationProfile",
      "description": "SME company details"
    },
    "/consultantProfiles/{userId}": {
      "schema": "ConsultantProfile",
      "description": "Consultant professional profile"
    },
    "/partnerProfiles/{userId}": {
      "schema": "PartnerProfile",
      "description": "Partner professional details"
    },
    "/serviceRequests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "SME service requests"
    },
    "/leadAssignments/{assignmentId}": {
      "schema": "LeadAssignment",
      "description": "Lead matches for consultants"
    }
  }
}
