rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Production security: enforce authenticated access and role-based authorization.
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /organisationProfiles/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /partnerProfiles/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /consultantProfiles/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /serviceRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.smeId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.smeId == request.auth.uid ||
        resource.data.consultantId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.smeId == request.auth.uid ||
        isAdmin() ||
        request.auth.uid == resource.data.selectedConsultantId
      );
      allow delete: if isAdmin();
    }

    match /leadAssignments/{assignmentId} {
      allow create: if isAuthenticated() && (
        request.auth.token.role == 'partner' || isAdmin()
      );
      allow read: if isAuthenticated() && (
        resource.data.partnerId == request.auth.uid ||
        resource.data.consultantId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isAdmin() || request.auth.uid == resource.data.consultantId
      );
      allow delete: if isAdmin();
    }

    match /requestBids/{bidId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.consultantId;
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.consultantId ||
        get(/databases/$(database)/documents/serviceRequests/$(resource.data.requestId)).data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/serviceRequests/$(resource.data.requestId)).data.leadOwnerId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isAdmin() || request.auth.uid == resource.data.consultantId
      );
      allow delete: if false;
    }

    match /emailTemplates/{templateId} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}