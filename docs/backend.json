
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user information and role",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["sme", "consultant", "admin"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "OrganisationProfile": {
      "title": "Organisation Profile",
      "description": "Detailed business info for SMEs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "industry": { "type": "string" },
        "employeeCount": { "type": "number" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ConsultantProfile": {
      "title": "Consultant Profile",
      "description": "Professional details for consultants",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "description": { "type": "string" },
        "yearsExperience": { "type": "number" },
        "servicesOffered": { "type": "array", "items": { "type": "string" }, "description": "Array of specific service IDs" },
        "statesCovered": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ServiceCategory": {
      "title": "Service Category",
      "description": "Broad category of services (e.g., Payroll)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SubService": {
      "title": "SubService",
      "description": "Specific granular service (e.g., PF Filing)",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "An SME's request for professional services",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceCategory": { "type": "string", "description": "Legacy field for backward compatibility" },
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "employeeCount": { "type": "number" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "description": { "type": "string" },
        "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
        "additionalNotes": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "assigned", "completed"] },
        "leadSource": { "type": "string", "enum": ["platform", "admin_manual", "linkedin", "google", "referral", "cold_outreach"] },
        "leadType": { "type": "string", "enum": ["inbound", "outbound"] },
        "createdByAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LeadAssignment": {
      "title": "Lead Assignment",
      "description": "Mapping of a request to a matching consultant",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "consultantId": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "viewed", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account data"
    },
    "/organisationProfiles/{userId}": {
      "schema": "OrganisationProfile",
      "description": "SME company details"
    },
    "/consultantProfiles/{userId}": {
      "schema": "ConsultantProfile",
      "description": "Consultant professional profile"
    },
    "/serviceCategories/{categoryId}": {
      "schema": "ServiceCategory",
      "description": "Service categories lookup"
    },
    "/services/{serviceId}": {
      "schema": "SubService",
      "description": "Specific services lookup"
    },
    "/serviceRequests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "SME service requests"
    },
    "/leadAssignments/{assignmentId}": {
      "schema": "LeadAssignment",
      "description": "Lead matches for consultants"
    }
  }
}
